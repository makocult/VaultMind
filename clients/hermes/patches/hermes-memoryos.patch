+class MemoryOSClient:
+    """Exact-entry MemoryOS backend for Hermes persistent memory."""
+
+    def __init__(
+        self,
+        *,
+        base_url: str,
+        fallback_url: Optional[str],
+        api_key: str,
+        agent_id: str,
+        timeout: float = 5.0,
+    ):
+        urls = [base_url.rstrip("/")]
+        if fallback_url:
+            normalized = fallback_url.rstrip("/")
+            if normalized not in urls:
+                urls.append(normalized)
+        self.base_urls = urls
+        self.api_key = api_key
+        self.agent_id = agent_id
+        self.timeout = timeout
+        self.session = requests.Session()
+        self.session.headers.update(
+            {
+                "X-Api-Key": api_key,
+                "X-Agent-Id": agent_id,
+                "Content-Type": "application/json",
+            }
+        )
+
+    @classmethod
+    def from_env(cls) -> Optional["MemoryOSClient"]:
+        base_url = (os.getenv("MEMORYOS_BASE_URL") or "").strip()
+        fallback_url = (os.getenv("MEMORYOS_FALLBACK_URL") or "").strip() or None
+        api_key = (os.getenv("MEMORYOS_API_KEY") or "").strip()
+        agent_id = (os.getenv("MEMORYOS_AGENT_ID") or "").strip()
+        timeout_raw = (os.getenv("MEMORYOS_TIMEOUT_SECONDS") or "5").strip()
+        try:
+            timeout = float(timeout_raw)
+        except ValueError:
+            timeout = 5.0
+        if not api_key or not agent_id or not (base_url or fallback_url):
+            return None
+        effective_base = base_url or fallback_url
+        return cls(
+            base_url=effective_base,
+            fallback_url=fallback_url if effective_base != fallback_url else None,
+            api_key=api_key,
+            agent_id=agent_id,
+            timeout=timeout,
+        )
+
+    def load_target_entries(self, target: str) -> List[str]:
+        records = self._list_target_records(target)
+        return [self._entry_text(record) for record in records if self._entry_text(record)]
+
+    def add_entry(self, target: str, content: str) -> None:
+        payload = {
+            "session_id": self._session_id(target),
+            "memory_type": MEMORYOS_MEMORY_TYPES[target],
+            "source_type": MEMORYOS_SOURCE_TYPE,
+            "source_ref": f"hermes://memory/{target}",
+            "summary": self._summary_for(content),
+            "body": content,
+            "tags": MEMORYOS_TAGS[target],
+            "stability": "high" if target == "user" else "medium",
+            "importance": 0.85 if target == "user" else 0.75,
+            "confidence": 0.95,
+            "consistency_score": 0.9,
+        }
+        self._request("POST", "/api/v1/memory/create", json=payload)
+
+    def replace_entry(self, target: str, old_text: str, new_content: str) -> None:
+        record = self._resolve_unique_record(target, old_text)
+        payload = {
+            "summary": self._summary_for(new_content),
+            "body": new_content,
+            "tags": MEMORYOS_TAGS[target],
+        }
+        self._request("PATCH", f"/api/v1/memory/{record['id']}", json=payload)
+
+    def remove_entry(self, target: str, old_text: str) -> None:
+        record = self._resolve_unique_record(target, old_text)
+        self._request("DELETE", f"/api/v1/memory/{record['id']}")
+
+    def _resolve_unique_record(self, target: str, old_text: str) -> Dict[str, Any]:
+        old_text = old_text.strip()
+        if not old_text:
+            raise ValueError("old_text cannot be empty.")
+
+        records = self._list_target_records(target)
+        matches = [(record, self._entry_text(record)) for record in records if old_text in self._entry_text(record)]
+        if not matches:
+            raise ValueError(f"No entry matched '{old_text}'.")
+        if len(matches) > 1:
+            unique_texts = {text for _, text in matches}
+            if len(unique_texts) > 1:
+                raise ValueError(f"Multiple entries matched '{old_text}'. Be more specific.")
+        return matches[0][0]
+
+    def _list_target_records(self, target: str) -> List[Dict[str, Any]]:
+        listed = self._request(
+            "POST",
+            "/api/v1/memory/list",
+            json={
+                "limit": MEMORYOS_CREATE_LIMIT,
+                "tags": [MEMORYOS_TAGS[target][1]],
+            },
+        )
+        records = []
+        for item in listed:
+            record = self._request("GET", f"/api/v1/memory/{item['id']}")
+            if self._target_tag(target) in record.get("tags", []):
+                records.append(record)
+        records.sort(key=lambda record: (record.get("timestamp") or "", record.get("created_at") or "", record["id"]))
+        return records
+
+    def _request(self, method: str, path: str, *, json: Dict[str, Any] = None) -> Any:
+        last_error: Optional[str] = None
+        for base_url in self.base_urls:
+            url = f"{base_url}{path}"
+            try:
+                response = self.session.request(method, url, json=json, timeout=self.timeout)
+                response.raise_for_status()
+                if response.content:
+                    return response.json()
+                return None
+            except requests.RequestException as exc:
+                last_error = f"{url}: {exc}"
+        raise RuntimeError(last_error or f"MemoryOS request failed for {path}")
+
+    @staticmethod
+    def _entry_text(record: Dict[str, Any]) -> str:
+        body = (record.get("body") or "").strip()
+        if body:
+            return body
+        return (record.get("summary") or "").strip()
+
+    @staticmethod
+    def _summary_for(content: str) -> str:
+        summary = re.sub(r"\s+", " ", content.strip())
+        if len(summary) <= 160:
+            return summary
+        return summary[:157].rstrip() + "..."
+
+    def _session_id(self, target: str) -> str:
+        explicit = (os.getenv("MEMORYOS_SESSION_ID") or os.getenv("HERMES_MEMORY_SESSION_ID") or "").strip()
+        if explicit:
+            return explicit
+        return f"hermes-memory:{self.agent_id}:{target}"
+
+    @staticmethod
+    def _target_tag(target: str) -> str:
+        return MEMORYOS_TAGS[target][2]
+
+
