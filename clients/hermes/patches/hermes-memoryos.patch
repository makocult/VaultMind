+class _FakeRemoteClient:
+    def __init__(self):
+        self.entries = {
+            "memory": ["Remote project uses MemoryOS"],
+            "user": ["User prefers concise replies"],
+        }
+
+    def load_target_entries(self, target):
+        return list(self.entries[target])
+
+    def add_entry(self, target, content):
+        self.entries[target].append(content)
+
+    def replace_entry(self, target, old_text, new_content):
+        for index, entry in enumerate(self.entries[target]):
+            if old_text in entry:
+                self.entries[target][index] = new_content
+                return
+        raise ValueError(f"No entry matched '{old_text}'.")
+
+    def remove_entry(self, target, old_text):
+        for index, entry in enumerate(self.entries[target]):
+            if old_text in entry:
+                self.entries[target].pop(index)
+                return
+        raise ValueError(f"No entry matched '{old_text}'.")
+
+
+class TestMemoryStoreMemoryOSBackend:
+    def test_remote_backend_loads_and_adds_entries(self, monkeypatch):
+        fake = _FakeRemoteClient()
+        monkeypatch.setattr("tools.memory_tool.MemoryOSClient.from_env", lambda: fake)
+
+        store = MemoryStore(memory_char_limit=500, user_char_limit=300)
+        store.load_from_disk()
+
+        snapshot = store.format_for_system_prompt("memory")
+        assert "Remote project uses MemoryOS" in snapshot
+
+        result = store.add("memory", "Hermes memory now writes to MemoryOS")
+        assert result["success"] is True
+        assert "Hermes memory now writes to MemoryOS" in fake.entries["memory"]
+
+    def test_remote_backend_replace_and_remove_entries(self, monkeypatch):
+        fake = _FakeRemoteClient()
+        monkeypatch.setattr("tools.memory_tool.MemoryOSClient.from_env", lambda: fake)
+
+        store = MemoryStore(memory_char_limit=500, user_char_limit=300)
+        store.load_from_disk()
+
+        replaced = store.replace("user", "concise", "User prefers very concise replies")
+        assert replaced["success"] is True
+        assert fake.entries["user"] == ["User prefers very concise replies"]
+
+        removed = store.remove("memory", "Remote project")
+        assert removed["success"] is True
+        assert fake.entries["memory"] == []
+
+
